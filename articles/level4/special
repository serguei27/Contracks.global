    var data=new FormData(form);var body=new URLSearchParams(data).toString();
    fetch('/',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body})
      .then(function(){unlock(false);window.scrollTo({top:0,behavior:'smooth'});})
      .catch(function(){unlock(false);window.scrollTo({top:0,behavior:'smooth'});});
  });}
  if(!document.documentElement.classList.contains('gate-locked')){
    if(document.readyState!=='loading')initScroll();else window.addEventListener('DOMContentLoaded',initScroll);
  }
  try{
    var qp=new URLSearchParams(window.location.search);
    if(qp.get('unlock')===REPORT && document.documentElement.classList.contains('gate-locked')){
      unlock(true);track('report_unlocked',{report:REPORT,lang:'en',via:'email_link'});
    }
  }catch(e){}
})();
</script>
</body>
</html>
