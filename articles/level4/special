<script>
const ARTICLE_SLUG = 'l4-specialreport-grow';
const AUDIO_BASE = '/audio';
const SELECTOR = '.article-deck, .article-body h2, .article-body h3, .article-body p, .article-body .objection-q';
const SENT_RE = /[^.!?]+[.!?]+(?:["'"')\]]+)?\s*|[^.!?]+$/g;
let spans={},block=[],N=0,times=null,cur=-1,state='idle',rate=1,MODE='browser';
function endOffsets(text){const re=new RegExp(SENT_RE.source,'g');let m,acc=0;const out=[];while((m=re.exec(text))!==null){if(m[0]===''){re.lastIndex++;continue;}acc+=m[0].length;out.push(acc);}return out.length?out:[text.length];}
function sidx(off,bounds){for(let i=0;i<bounds.length;i++)if(off<bounds[i])return i;return bounds.length-1;}
function mkSpan(text,si){const s=document.createElement('span');s.className='s';s.dataset.si=si;s.textContent=text;return s;}
function wrapEl(el,ctx){[...el.childNodes].forEach(child=>{if(child.nodeType===3){const txt=child.nodeValue,frag=document.createDocumentFragment();let buf='',c0=sidx(ctx.off,ctx.bounds);for(let c=0;c<txt.length;c++){const gi=sidx(ctx.off,ctx.bounds);if(gi!==c0&&buf!==''){frag.appendChild(mkSpan(buf,ctx.base+c0));buf='';c0=gi;}buf+=txt[c];ctx.off++;}if(buf!=='')frag.appendChild(mkSpan(buf,ctx.base+c0));el.replaceChild(frag,child);}else if(child.nodeType===1){wrapEl(child,ctx);}});}
function build(){document.querySelectorAll(SELECTOR).forEach(node=>{if(node.closest('.article-cta'))return;node.classList.add('read-block');const raw=node.textContent;const bounds=endOffsets(raw);wrapEl(node,{off:0,bounds,base:N});for(let i=0;i<bounds.length;i++)block[N+i]=node;N+=bounds.length;});document.querySelectorAll('.s').forEach(s=>{const i=+s.dataset.si;(spans[i]=spans[i]||[]).push(s);s.onclick=()=>cksSeekSentence(i);});const words=document.querySelector('.article-body').textContent.trim().split(/\s+/).length;document.getElementById('cksListenTime').textContent='· '+Math.max(1,Math.round(words/150))+' min';}
function sentText(i){return(spans[i]||[]).map(s=>s.textContent).join('');}
function highlight(i){if(i===cur||i<0||i>=N)return;if(cur>=0&&spans[cur])spans[cur].forEach(s=>{s.classList.remove('active');s.classList.add('read');});for(let k=Math.max(0,cur);k<i;k++)spans[k]?.forEach(s=>s.classList.add('read'));cur=i;spans[i]?.forEach(s=>{s.classList.remove('read');s.classList.add('active');});document.querySelectorAll('.read-block.block-active').forEach(b=>b.classList.remove('block-active'));const blk=block[i];blk?.classList.add('block-active');document.getElementById('cksNow').textContent=sentText(i).trim().slice(0,80);if(blk){const r=blk.getBoundingClientRect(),vh=innerHeight;if(r.top<vh*0.2||r.bottom>vh-150)scrollTo({top:scrollY+r.top-vh*0.32,behavior:'smooth'});}}
function clearAll(){document.querySelectorAll('.s.active,.s.read').forEach(s=>s.classList.remove('active','read'));document.querySelectorAll('.block-active').forEach(b=>b.classList.remove('block-active'));cur=-1;}
let audio=null;
function timeToSentence(t){let i=0;for(let k=0;k<times.length;k++){if(t>=times[k].start)i=k;else break;}return i;}
function elInit(){audio=new Audio(`${AUDIO_BASE}/${ARTICLE_SLUG}.mp3`);audio.preload='metadata';audio.addEventListener('timeupdate',()=>{const t=audio.currentTime,dur=audio.duration||times.at(-1).end;if(times)highlight(Math.min(timeToSentence(t),N-1));setProgress(t/dur*100);setStatus(remain(dur-t));});audio.addEventListener('ended',finish);}
const elEngine={play(){if(!audio)elInit();audio.playbackRate=rate;audio.play();},pause(){audio&&audio.pause();},stop(){if(audio){audio.pause();audio.currentTime=0;}},seekSentence(i){if(!audio)elInit();if(times)audio.currentTime=times[Math.min(i,times.length-1)].start;if(state==='playing')audio.play();},seekFraction(f){if(!audio)elInit();audio.currentTime=f*(audio.duration||(times?times.at(-1).end:0));if(state==='playing')audio.play();},setRate(r){if(audio)audio.playbackRate=r;}};
let voice=null,smooth=null;
function pickVoice(){const v=speechSynthesis.getVoices();voice=v.find(x=>x.name==='Daniel'&&x.lang==='en-GB')||v.find(x=>x.lang==='en-GB')||v.find(x=>x.lang.startsWith('en'));}
function speakFrom(i){if(i>=N){finish();return;}highlight(i);const u=new SpeechSynthesisUtterance(sentText(i));u.rate=rate;if(voice)u.voice=voice;startSmooth(i);u.onend=()=>{if(state==='playing'){stopSmooth();speakFrom(i+1);}};u.onerror=e=>{if(e.error!=='interrupted'&&state==='playing'){stopSmooth();speakFrom(i+1);}};speechSynthesis.speak(u);}
function len(i){return sentText(i).length;}
function startSmooth(i){stopSmooth();let total=0,before=0;for(let k=0;k<N;k++){const l=len(k);if(k<i)before+=l;total+=l;}const dur=Math.max(800,len(i)/(14.5*rate)*1000),t0=performance.now();smooth=setInterval(()=>{const f=Math.min(1,(performance.now()-t0)/dur);setProgress((before+len(i)*f)/total*100);},120);}
function stopSmooth(){if(smooth){clearInterval(smooth);smooth=null;}}
const brEngine={play(){if(state==='paused')speechSynthesis.resume();else{speechSynthesis.cancel();speakFrom(cur<0?0:cur);}},pause(){speechSynthesis.pause();stopSmooth();},stop(){speechSynthesis.cancel();stopSmooth();},seekSentence(i){speechSynthesis.cancel();stopSmooth();cur=i-1;if(state==='playing')speakFrom(i);else highlight(i);},seekFraction(f){this.seekSentence(Math.floor(f*N));},setRate(){if(state==='playing'){const i=cur;speechSynthesis.cancel();stopSmooth();speakFrom(i);}}};
const plainEngine={play(){if(!audio)elInit();audio.playbackRate=rate;audio.play();},pause(){audio&&audio.pause();},stop(){if(audio){audio.pause();audio.currentTime=0;}},seekSentence(){},seekFraction(f){if(!audio)elInit();audio.currentTime=f*(audio.duration||0);if(state==='playing')audio.play();},setRate(r){if(audio)audio.playbackRate=r;}};
let E=brEngine;
function cksToggle(){if(document.documentElement.classList.contains('gate-locked')){flashGate();return;}if(state!=='playing'){track('audio_play',{report:'grow'});}state==='playing'?cksPause():play();}
function play(){if(state==='done')clearAll();if(MODE!=='plain'){document.body.classList.add('listening');if(state!=='paused'&&cur<0)highlight(0);}state='playing';setUI(true);E.play();}
function cksPause(){state='paused';setUI(false);E.pause();setStatus('Paused');}
function cksStop(){state='idle';setUI(false);E.stop();stopSmooth();clearAll();document.body.classList.remove('listening');setProgress(0);setStatus(label());document.getElementById('cksNow').textContent='Press play to begin';}
function finish(){state='done';setUI(false);stopSmooth();setProgress(100);setStatus('Finished');document.getElementById('cksNow').textContent='Report complete';document.body.classList.remove('listening');if(window.track)track('read_complete',{report:'grow',via:'audio'});}
function cksSeekSentence(i){if(MODE==='plain')return;if(state==='idle')play();E.seekSentence(i);highlight(i);}
function cksSeek(e){const r=e.currentTarget.getBoundingClientRect();E.seekFraction((e.clientX-r.left)/r.width);}
function cksRate(r){rate=r;document.querySelectorAll('.cks-spd').forEach(b=>b.classList.toggle('on',parseFloat(b.textContent)===r));E.setRate(r);}
function setProgress(p){document.getElementById('cksFill').style.width=Math.min(100,Math.max(0,p))+'%';}
function setStatus(s){document.getElementById('cksStatus').textContent=s;}
function remain(sec){sec=Math.max(0,Math.round(sec));const m=Math.floor(sec/60),s=sec%60;return m>0?`${m}m ${s}s left`:`${s}s left`;}
function setUI(on){document.getElementById('cksIcon').innerHTML=on?'<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>':'<polygon points="6,4 20,12 6,20"/>';document.getElementById('cksPlayer').classList.toggle('playing',on);document.getElementById('cksListenLabel').textContent=on?'Pause':'Listen to this report';}
function label(){return MODE==='el'?'Contracks Global Insights':MODE==='plain'?'Audio report':'Browser voice (preview)';}
function applySrc(){const l=document.getElementById('cksSrcL');l.textContent=MODE==='el'?'ELEVENLABS':MODE==='plain'?'AUDIO':'BROWSER';if(MODE==='el'&&times){const d=times.at(-1)?.end||0;document.getElementById('cksListenTime').textContent='· '+Math.max(1,Math.round(d/60))+' min';}if(MODE!=='plain')document.querySelector('.article-body').classList.add('clickable');setStatus(label());}
window.addEventListener('DOMContentLoaded',async()=>{build();if(!document.documentElement.classList.contains('gate-locked')){document.getElementById('cksPlayer').classList.add('show');}try{const r=await fetch(`${AUDIO_BASE}/${ARTICLE_SLUG}.sentences.json`,{cache:'no-cache'});if(!r.ok)throw 0;const d=await r.json();times=d.sentences;if(!Array.isArray(times)||!times.length)throw 0;if(times.length!==N)console.warn(`Sentence mismatch: audio ${times.length} vs page ${N}`);MODE='el';E=elEngine;applySrc();return;}catch(e){}try{const h=await fetch(`${AUDIO_BASE}/${ARTICLE_SLUG}.mp3`,{headers:{Range:'bytes=0-1'},cache:'no-store'});if(h.ok&&(h.status===200||h.status===206)){MODE='plain';E=plainEngine;applySrc();return;}}catch(e){}MODE='browser';E=brEngine;pickVoice();speechSynthesis.onvoiceschanged=pickVoice;speechSynthesis.getVoices();applySrc();});
window.addEventListener('beforeunload',()=>{if(MODE==='browser')speechSynthesis.cancel();});
</script>

<script>
