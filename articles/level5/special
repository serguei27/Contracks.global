function setUI(on){document.getElementById('cksIcon').innerHTML=on?'<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>':'<polygon points="6,4 20,12 6,20"/>';document.getElementById('cksPlayer').classList.toggle('playing',on);document.getElementById('cksListenLabel').textContent=on?'Pause':'Listen to this report';}
function label(){return MODE==='el'?'Contracks Global Insights':MODE==='plain'?'Audio article':'Audio version coming soon';}
function applySrc(){const l=document.getElementById('cksSrcL');l.textContent=MODE==='el'?'ELEVENLABS':MODE==='plain'?'AUDIO':'SOON';if(MODE==='el'&&times){const d=times.at(-1)?.end||0;document.getElementById('cksListenTime').textContent='· '+Math.max(1,Math.round(d/60))+' min';}if(MODE!=='plain')document.querySelector('main').classList.add('clickable');setStatus(label());}
window.addEventListener('DOMContentLoaded',async()=>{build();if(!document.documentElement.classList.contains('gate-locked')){document.getElementById('cksPlayer').classList.add('show');}try{const r=await fetch(`${AUDIO_BASE}/${ARTICLE_SLUG}.sentences.json`,{cache:'no-cache'});if(!r.ok)throw 0;const d=await r.json();times=d.sentences;if(!Array.isArray(times)||!times.length)throw 0;if(times.length!==N)console.warn(`Sentence mismatch: audio ${times.length} vs page ${N}`);MODE='el';E=elEngine;applySrc();return;}catch(e){}try{const h=await fetch(`${AUDIO_BASE}/${ARTICLE_SLUG}.mp3`,{headers:{Range:'bytes=0-1'},cache:'no-cache'});if(h.ok||h.status===206){MODE='plain';E=plainEngine;applySrc();return;}}catch(e){}MODE='browser';E=brEngine;pickVoice();speechSynthesis.onvoiceschanged=pickVoice;speechSynthesis.getVoices();applySrc();});
window.addEventListener('beforeunload',()=>{if(MODE==='browser')speechSynthesis.cancel();});
</script>

<script>
(function(){
  var REPORT='control';
  function track(ev,props){props=props||{};try{if(window.plausible){window.plausible(ev,{props:props});return;}}catch(e){}try{window.dataLayer=window.dataLayer||[];window.dataLayer.push(Object.assign({event:ev},props));}catch(e){}}
  window.track=track;
  window.flashGate=function(){var g=document.getElementById('gate');if(!g)return;g.scrollIntoView({behavior:'smooth',block:'start'});};
  function unlock(silent){
    try{localStorage.setItem('cks_gate_'+REPORT,'unlocked');}catch(e){}
    document.documentElement.classList.remove('gate-locked');
    var g=document.getElementById('gate');if(g)g.style.display='none';
    var p=document.getElementById('cksPlayer');if(p)p.classList.add('show');
    if(typeof cksDetect==='function'){try{cksDetect();}catch(e){}}
    if(!silent)track('report_unlocked',{report:REPORT,lang:'en'});
    initScroll();
  }
  var fired={};
  function initScroll(){
    var main=document.querySelector('main.article-body');if(!main)return;
    function onScroll(){
      var total=main.offsetHeight-window.innerHeight;if(total<=0)return;
      var pct=Math.min(100,Math.max(0,((window.scrollY+window.innerHeight)-main.offsetTop)/main.offsetHeight*100));
      [25,50,75,100].forEach(function(m){if(pct>=m&&!fired[m]){fired[m]=true;track('scroll_'+m,{report:REPORT});if(m===100)track('read_complete',{report:REPORT,via:'scroll'});}});
    }
    window.addEventListener('scroll',onScroll,{passive:true});onScroll();
  }
  var dl=document.getElementById('ubDownload');if(dl)dl.addEventListener('click',function(){track('pdf_download',{report:REPORT});});
  var form=document.getElementById('gateForm');
  if(form){form.addEventListener('submit',function(e){
    e.preventDefault();
    var btn=document.getElementById('gateSubmit');if(btn){btn.disabled=true;btn.textContent='Unlocking\u2026';}
    var data=new FormData(form);var body=new URLSearchParams(data).toString();
    fetch('/',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body})
      .then(function(){unlock(false);window.scrollTo({top:0,behavior:'smooth'});})
      .catch(function(){unlock(false);window.scrollTo({top:0,behavior:'smooth'});});
  });}
  if(!document.documentElement.classList.contains('gate-locked')){
    if(document.readyState!=='loading')initScroll();else window.addEventListener('DOMContentLoaded',initScroll);
  }
  try{
    var qp=new URLSearchParams(window.location.search);
    if(qp.get('unlock')===REPORT && document.documentElement.classList.contains('gate-locked')){
      unlock(true);track('report_unlocked',{report:REPORT,lang:'en',via:'email_link'});
    }
  }catch(e){}
})();
</script>
</body>
</html>
